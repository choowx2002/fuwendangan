{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "http:default",
    "fs:default",
    "fs:allow-write",
    "fs:allow-appdata-write",
    "fs:allow-appdata-write-recursive",
    "fs:scope-cache-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPCACHE"
        },
        {
          "path": "$APPCACHE/**"
        },
        {
          "path": "$APPCACHE/**/*"
        },
        {
          "path": "$RESOURCE/resources/external"
        },
        {
          "path": "$RESOURCE/resources/external/**/*"
        },
        {
          "path": "$APPLOCALDATA"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPLOCALDATA/**/*"
        }
      ]
    },
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://cdn.playloltcg.com/**" },
        { "url": "https://steamusercontent-a.akamaihd.net/**" },
        { "url": "https://**" }
      ]
    }
  ]
}
